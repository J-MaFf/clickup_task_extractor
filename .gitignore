# General
.DS_Store
Thumbs.db
*.log

# Dependencies
node_modules/

# IDE
.vscode/extensions.json
.vscode/*.log
.vscode/clickup_task_extractor.code-workspace

# Environment
.env
.env.local
.env.*
# Keep the committed example templates (they contain no real secrets)
!.env.example
!.env.kfj.example
*.pem

# Dependency lock file is intentionally tracked (some global gitignores
# exclude *.lock; re-include it here so it is committed everywhere).
!requirements.lock

# OS
*.swp
*.swo
*~

# Python
__pycache__/
*.pyc
*.pyo

# Project-specific
output/
test_outputs/
build/
dist/
*.spec
.github/Python.prompt.md

# Note: knowledge-graph.jsonl is intentionally NOT ignored
# It will be tracked in Git for backup and sync purposes

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
